{
  "name": "hxaxd-research-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.e2e.json --pretty false",
    "lint": "oxlint --deny-warnings src",
    "test": "vitest run src",
    "test:e2e": "playwright test",
    "test:e2e:fullstack": "npm run build && playwright test --config playwright.fullstack.config.ts",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "pdfjs-dist": "6.1.200",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.10",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "oxlint": "1.74.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
